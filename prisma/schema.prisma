generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  nickname  String   @unique
  deviceId  String?  @unique
  createdAt DateTime @default(now())
  analyses  Analysis[]
}

model Analysis {
  id                 String   @id @default(cuid())
  userId             String?
  user               User?    @relation(fields: [userId], references: [id])
  kickerHeightPx     Float?
  ballDisplacementPx Float?
  estimatedSpeedKmh  Float
  formScore          Int
  kickType           String?
  createdAt          DateTime @default(now())
}

model ReferenceVideo {
  id                  String   @id @default(cuid())
  label               String
  sourceFilename      String?
  sourceMimeType      String?
  sourceSizeBytes     Int?
  sourceUrl           String?
  knownSpeedKmh       Float
  measuredSpeedKmh    Float
  knownDistanceMeters Float?
  ballDisplacementPx  Float?
  bodyHeightPx        Float?
  metersPerPixel      Float?
  videoWidth          Int?
  videoHeight         Int?
  durationSeconds     Float?
  fps                 Float?
  timingStartSeconds  Float?
  timingEndSeconds    Float?
  timingSpeedKmh      Float?
  playerHeightCm      Float?
  cameraAngle         String?
  calibrationFactor   Float
  isActive            Boolean  @default(true)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([isActive, createdAt])
}
